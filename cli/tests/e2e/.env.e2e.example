# E2E test environment — copy to .env.e2e (same directory) and fill in.
#
# .env.e2e is loaded with override=True before the cli package is imported,
# so it wins over the shell and the repo-root .env. Every key listed here is
# pre-seeded as empty when missing from .env.e2e, so values never silently
# fall back to the root .env.

# --- e2e-specific settings ---
SPTOOL_PATH=
E2E_HTTP_PORT=18080
E2E_USE_NGROK=true
E2E_TIMEOUT_SECONDS=180
E2E_POLL_INTERVAL_SECONDS=3
E2E_ECHO_CLI=true

# --- CLI configuration (same keys as the root .env) ---
RPC_URL=
DEBUG=
DRY_RUN=

POREP_MARKET=
SP_REGISTRY=
SLI_ORACLE=
SLI_SCORER=
FILECOIN_PAY=
USDC_TOKEN=
META_ALLOCATOR=
ALLOCATOR_FACTORY=
VALIDATOR_FACTORY=

ADMIN_PRIVATE_KEY=
ADMIN_SIGN_METHOD=
ADMIN_LOTUS_WALLET=

CLIENT_CONTRACT=
CLIENT_PRIVATE_KEY=
CLIENT_SIGN_METHOD=
CLIENT_LOTUS_WALLET=

SP_PRIVATE_KEY=
SP_SIGN_METHOD=
SP_LOTUS_WALLET=
SP_ORGANIZATION=

SP_REGISTRY_DATABASE_URL=

LOTUS_TOKEN=
BOOSTD_PATH=
CURIO_PATH=

PRIVATE_KEY_SP=
PRIVATE_KEY_TEST=
NGROK_PUBLIC_URL=
